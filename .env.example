# AWS Configuration (for Bedrock embeddings)
AWS_REGION=us-west-2

# Qdrant Vector Database (Recommended)
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key-here

# OpenSearch Serverless (Alternative - requires AWS setup)
AOSS_VECTORSEARCH_ENDPOINT=your-opensearch-endpoint-here

# Anthropic API Configuration (for Claude models)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Note: Claude Mythos 5 requires Project Glasswing participation
# If you don't have access, the system will automatically use Claude Opus 4.8
